<?xml version="1.0" encoding="UTF-8"?>
<aiml version="2.0">

  <!-- EMERGENCY NUMBERS -->
  <category>
    <pattern>EMERGENCY</pattern>
    <template>Emergency Helpline Numbers:
🚑 Ambulance: 108 (Free, 24x7 — All India)
🚑 Ambulance (alternate): 102
👮 Police: 112
📞 Health Helpline: 104 (Free medical advice)
👩 Women Helpline: 1091
👶 Child Helpline: 1098
🏥 Ayushman Bharat: 14555
🧠 Mental Health: 9152987821 (iCall)
☠️ Poison Control: 1800-116-117 (Toll-free)
Call 108 for ANY medical emergency — it is FREE.</template>
  </category>

  <category>
    <pattern>HELPLINE</pattern>
    <template><srai>EMERGENCY</srai></template>
  </category>

  <category>
    <pattern>HELPLINE NUMBERS</pattern>
    <template><srai>EMERGENCY</srai></template>
  </category>

  <!-- AMBULANCE -->
  <category>
    <pattern>AMBULANCE</pattern>
    <template>CALL 108 NOW for a free ambulance — available 24x7 across India.
Alternate number: 102
The ambulance service is completely FREE for all medical emergencies.
Stay on the line and give your exact location and the patient's condition.</template>
  </category>

  <category>
    <pattern>CALL AMBULANCE</pattern>
    <template><srai>AMBULANCE</srai></template>
  </category>

  <category>
    <pattern>I NEED AMBULANCE</pattern>
    <template><srai>AMBULANCE</srai></template>
  </category>

  <!-- FIND HOSPITAL -->
  <category>
    <pattern>NEAREST HOSPITAL</pattern>
    <template>To find the nearest hospital, please tell me your district or pincode.
For example, type: HOSPITAL IN AGRA or HOSPITAL IN 282001
I will find the nearest PHC, CHC, or District Hospital for you.</template>
  </category>

  <category>
    <pattern>FIND HOSPITAL</pattern>
    <template><srai>NEAREST HOSPITAL</srai></template>
  </category>

  <category>
    <pattern>HOSPITAL NEAR ME</pattern>
    <template><srai>NEAREST HOSPITAL</srai></template>
  </category>

  <category>
    <pattern>NEAREST PHC</pattern>
    <template>To find the nearest Primary Health Centre (PHC), type:
HOSPITAL IN followed by your district name.
Example: HOSPITAL IN VARANASI
PHCs provide free basic healthcare, medicines, and maternal health services.</template>
  </category>

  <category>
    <pattern>PRIMARY HEALTH CENTER</pattern>
    <template><srai>NEAREST PHC</srai></template>
  </category>

